root = true

# All files
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Package.json and lock files
[{package.json,pnpm-lock.yaml}]
indent_size = 2

# TypeScript/JavaScript files
[*.{js,ts}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Configuration files
[*config.{js,ts}]
indent_size = 2
